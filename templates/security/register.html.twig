{% extends 'base.html.twig' %}

{% block title %}Maudule-Studio - Sign up{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/assets/style/Account.css">
{% endblock %}

{% block body %}
    <section class="auth-page">
        <div class="auth-card">
            <h1>Sign up</h1>
            <p class="auth-subtitle">Create your account to start posting listings.</p>
            {% for message in app.flashes('error') %}
                <p class="error">{{ message }}</p>
            {% endfor %}
            <form method="post">
                <div class="form-group">
                    <label for="mail">Email</label>
                    <input type="email" id="mail" name="mail" required placeholder="your@email.com">
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required placeholder="Choose a password">
                </div>
                <button type="submit">Sign up</button>
            </form>
            <div class="auth-footer">
                Already have an account? <a href="{{ path('app_login') }}">Log in</a>
            </div>
        </div>
    </section>
{% endblock %}
