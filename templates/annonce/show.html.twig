{% extends 'base.html.twig' %}

{% block title %}{{ annonce.nom }}{% endblock %}

{% block body %}
    <section style="margin-top: 40px;">
        <div class="boite" style="margin: auto; width: 350px;">
            <div class="boitehaut">
                <div class="picture" style="background-image: url('/{{ annonce.frontPicture }}'); --back-picture: url('/{{ annonce.backPicture }}')">
                    <div class="midlebox">
                        <div class="coeur"></div>
                        <div class="conatinerouge">
                            <div class="rouge">{{ annonce.typeTransaction == 'vente' ? 'SALE' : 'RENT' }}</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bas">
                <div class="nom">
                    <div class="t">{{ annonce.nom }}</div>
                    <div>{{ annonce.prix }}</div>
                </div>
                <div class="bold">{{ annonce.ville }}</div>
                <div class="description">{{ annonce.descriptions }}</div>
                <div style="color: rgb(151, 172, 179); font-size: 12px; margin-top: 5px;">Publiée par : {{ annonce.user.mail }}</div>
            </div>
        </div>

        {% if app.user and app.user.id == annonce.user.id %}
            <div style="display: flex; justify-content: center; gap: 20px; margin-top: 20px;">
                <a href="{{ path('annonce_edit', {id: annonce.id}) }}" class="bouton" style="width: 120px; height: 40px; font-size: 18px;">Modifier</a>
                <form method="post" action="{{ path('annonce_delete', {id: annonce.id}) }}" onsubmit="return confirm('Supprimer cette annonce ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ annonce.id) }}">
                    <button type="submit" class="out" style="width: 120px; height: 40px; font-size: 18px; border: none;">Supprimer</button>
                </form>
            </div>
        {% endif %}

        <div style="display: flex; justify-content: center; margin-top: 20px;">
            <a href="{{ path('home') }}" class="bouton" style="width: 160px; height: 40px; font-size: 18px;">Retour</a>
        </div>
    </section>
{% endblock %}
