{% extends 'base.html.twig' %}

{% block title %}Maudule-Studio{% endblock %}

{% block body %}
    <main>
        {# START FIRST SECTION HOME #}
        <section class="premier">
            <div class="margeL margeT">Welcome on MAUDULE STUDIO</div>
            <article class="second">
                <div class="left">
                    <div class="tit marge">Discover your living dream property </div>
                    <div class="marge">Working with us and find your dream property. We provide comfortable prices for our client so don't delay.</div>
                    <div class="bar">
                        <div class="bar">
                            <div class="buton">
                                <div class="buy active" id="btnBuy"> Buy</div>
                                <div class="buy active" id="btnRent">Rent</div>
                            </div>
                            <div class="search">
                                <div class="search-bar"></div>
                                <div class="flex">
                                    <div class="margeD"><img src="/assets/img/icone/1814106_location_map_marker_icon 1.png" width="33px" height="33px"></div>
                                    <input type="text" id="searchLocation" placeholder="Search by location" style="border:none;outline:none;background:transparent;font-family:DM;font-size:16px;width:140px;color:#333;">
                                </div>
                                <div class="Bsearch">
                                    <div><img src="/assets/img/icone/Icon.png"></div>
                                    <div class="Search" id="btnSearch" style="cursor:pointer;">
                                        <div><img src="/assets/img/icone/search.png"></div>
                                        <div>Search</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="containere">
                    <div class="right"></div>
                </div>
            </article>
        </section>
        {# END FIRST SECTION HOME #}

        {# START SECOND SECTION HOME #}
        <section class="fond">
            <div class="box">
                <div><img src="/assets/img/pageHome/buy.png" width="245px" height="245px"></div>
                <div class="margeB pub">Buy a property</div>
                <div>Elevate your property purchase with our precise valuations, broad exposure, and personalized guidance.</div>
                <a href="{{ path('listing_houses') }}" class="find">Find a home</a>
            </div>
            <div class="box margeD margeL">
                <div><img src="/assets/img/pageHome/sale.png" width="245px" height="245px"></div>
                <div class="margeB pub">Sell or Rent property</div>
                <div>Explore our sales services: accurate valuation, maximum visibility, personalized support. Sell successfully, choose quality.</div>
                {% if app.user %}
                    <a href="{{ path('annonce_new') }}" class="find">Place an ad</a>
                {% else %}
                    <a href="{{ path('app_account') }}" class="find">Place an ad</a>
                {% endif %}
            </div>
            <div class="box">
                <div><img src="/assets/img/pageHome/property.png"></div>
                <div class="margeB pub">Rent a property</div>
                <div>Discover our rental services: diverse choices, straightforward process, dedicated customer service.</div>
                <a href="{{ path('listing_apartments') }}" class="find">Find a rental</a>
            </div>
        </section>
        {# ENDSECOND SECTION HOME #}

        {# START SECTION SALE #}
        <section class="sale">
            <div class="grent">
                <div class="title">NEW SALE</div>
                <div class="stitle margeL">Our most recent projects </div>
                <a href="{{ path('listing_houses') }}" class="see">see everything</a>
            </div>
            <div class="slider-wrapper">
                <button class="slider-arrow slider-arrow-left" data-dir="left">&lsaquo;</button>
                <div class="containerSale">
                    {% for annonce in annonces_vente %}
                        <div class="boite">
                            <div class="boitehaut">
                                <div class="picture" style="background-image: url('/{{ annonce.frontPicture }}'); --back-picture: url('/{{ annonce.backPicture }}')">
                                    <div class="midlebox">
                                        <div class="coeur">
                                            <input type="checkbox" id="coeurCheckbox{{ annonce.id }}">
                                            <label for="coeurCheckbox{{ annonce.id }}"><img src="/assets/img/icone/290111_favorite_heart_like_love_valentine_icon.svg" alt="Coeur"></label>
                                        </div>
                                        <div class="conatinerouge">
                                            <div class="rouge">SALE</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="bas">
                                <div class="nom">
                                    <div class="t">{{ annonce.nom }}</div>
                                    <div>{{ annonce.prix }}</div>
                                </div>
                                <div class="bold">{{ annonce.ville }}</div>
                                <div class="description">{{ annonce.descriptions }}</div>
                                <div class="cont">CONTACT</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <button class="slider-arrow slider-arrow-right" data-dir="right">&rsaquo;</button>
            </div>
        </section>
        {# END SECTION SALE #}

        {# START SECTION RENT #}
        <section class="rent">
            <div class="grent">
                <div class="title">NEW RENT</div>
                <div class="stitle margeL">Our most recent projects </div>
                <a href="{{ path('listing_apartments') }}" class="see">see everything</a>
            </div>
            <div class="slider-wrapper">
                <button class="slider-arrow slider-arrow-left" data-dir="left">&lsaquo;</button>
                <div class="containerSale">
                    {% for annonce in annonces_location %}
                        <div class="boite">
                            <div class="boitehaut">
                                <div class="picture" style="background-image: url('/{{ annonce.frontPicture }}'); --back-picture: url('/{{ annonce.backPicture }}')">
                                    <div class="midlebox">
                                        <div class="coeur">
                                            <input type="checkbox" id="coeurCheckboxRent_{{ annonce.id }}">
                                            <label for="coeurCheckboxRent_{{ annonce.id }}"><img src="/assets/img/icone/290111_favorite_heart_like_love_valentine_icon.svg" alt="Coeur"></label>
                                        </div>
                                        <div class="conatinerouge">
                                            <div class="rouge">RENT</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="bas">
                                <div class="nom">
                                    <div class="t">{{ annonce.nom }}</div>
                                    <div>{{ annonce.prix }}</div>
                                </div>
                                <div class="bold">{{ annonce.ville }}</div>
                                <div class="description">{{ annonce.descriptions }}</div>
                                <div class="cont">CONTACT</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <button class="slider-arrow slider-arrow-right" data-dir="right">&rsaquo;</button>
            </div>
        </section>
        {# END SECTION RENT #}

        {# START SECTION SOURCING #}
        <section class="sourcing">
            <div class="margeT direction">SOURCING</div>
            <section class="disposition">
                <div class="container">
                    <div class="rond house "></div>
                    <div class="titre margeB">Explore you future home</div>
                    <div class="stitre">Choose your home with us for a seamless and memorable experience in finding the perfect place to call your own. Discover your perfect home seamlessly with us. From cozy apartments to charming houses, our guided process ensures a memorable and effortless experience. Your dream home is just a step away.</div>
                </div>
                <div class="container">
                    <div class="rond im margeB"></div>
                    <div class="titre margeB">Discover Your Ideal Apartment</div>
                    <div class="stitre">Select your ideal apartment effortlessly with us, ensuring a smooth and unforgettable journey in finding your perfect living space. From cozy abodes to stylish residences, each step is guided, making your home selection simple and memorable. Your dream apartment is just a step away with us.</div>
                </div>
                <div class="container">
                    <div class="rond tel margeB"></div>
                    <div class="titre margeB">Register and post your ads</div>
                    <div class="stitre">List your properties with us for optimal exposure and a stress-free selling or renting experience. From accurate property assessments to personalized support, we streamline the process for your convenience. Choose us for a seamless and successful real estate journey.</div>
                </div>
            </section>
        </section>
        {# END SECTION SOURCING #}

        {# START SECTION CONTACT #}
        <section id="contacte" class="contact">
            <div class="lefte">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="flash-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
                <form method="post" action="{{ path('home') }}#contacte">
                    <div>CONTACT US</div>
                    <label for="name">Name:</label><br>
                    <input type="text" id="name" name="contact_name" required /><br>
                    <label for="email">E-mail:</label><br>
                    <input type="email" id="email" name="contact_email" required /><br>
                    <label for="interest">Interest by:</label><br>
                    <select id="interest" name="interest">
                        <option value="sale">Sale</option>
                        <option value="rent">Rent</option>
                        <option value="other">Other</option>
                    </select><br>
                    <label for="message">Message:</label><br>
                    <textarea id="message" name="message" required></textarea><br>
                    <input type="submit" value="Send" />
                </form>
            </div>
            <div class="righte">
                <div class="contactimg"></div>
            </div>
        </section>
        {# END SECTION CONTACT #}
    </main>

    <script>
        // Drag scroll
        document.querySelectorAll('.containerSale').forEach(function(container) {
            container.addEventListener('mousemove', function(event) {
                if (event.buttons === 1) {
                    container.scrollLeft -= event.movementX;
                }
            });
        });

        // Arrow scroll
        document.querySelectorAll('.slider-arrow').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var container = this.closest('.slider-wrapper').querySelector('.containerSale');
                var scrollAmount = 380;
                if (this.dataset.dir === 'left') {
                    container.scrollLeft -= scrollAmount;
                } else {
                    container.scrollLeft += scrollAmount;
                }
            });
        });

        // Buy / Rent toggle
        const btnBuy = document.getElementById('btnBuy');
        const btnRent = document.getElementById('btnRent');
        const sectionSale = document.querySelector('section.sale');
        const sectionRent = document.querySelector('section.rent');

        btnBuy.addEventListener('click', function() {
            this.classList.toggle('active');
            applyFilters();
        });

        btnRent.addEventListener('click', function() {
            this.classList.toggle('active');
            applyFilters();
        });

        // Search by location
        const searchInput = document.getElementById('searchLocation');
        const btnSearch = document.getElementById('btnSearch');

        btnSearch.addEventListener('click', function() {
            applyFilters();
        });

        searchInput.addEventListener('keyup', function(e) {
            if (e.key === 'Enter') applyFilters();
        });

        function applyFilters() {
            const query = searchInput.value.trim().toLowerCase();
            const showSale = btnBuy.classList.contains('active');
            const showRent = btnRent.classList.contains('active');

            // Show/hide sections
            sectionSale.style.display = showSale ? '' : 'none';
            sectionRent.style.display = showRent ? '' : 'none';

            // Filter cards by ville
            filterCards(sectionSale, query);
            filterCards(sectionRent, query);
        }

        function filterCards(section, query) {
            const cards = section.querySelectorAll('.boite');
            cards.forEach(function(card) {
                const ville = card.querySelector('.bold');
                if (!query || (ville && ville.textContent.toLowerCase().includes(query))) {
                    card.style.display = '';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
{% endblock %}